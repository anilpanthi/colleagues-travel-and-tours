# Database Configuration
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/colleagues-travel-and-tours
PAYLOAD_SECRET=YOUR_SECRET_HERE
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# Server Configuration
# Use the canonical public URL without www. The app redirects www requests here.
NEXT_PUBLIC_SERVER_URL=https://colleaguestravel.com

# Google reCAPTCHA (required in production only)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_MIN_SCORE=0.3

# Transactional email (Resend)
# Verify updates.colleaguestravel.com in Resend before using this sender.
# Mailcow remains responsible for mailboxes and incoming mail on colleaguestravel.com.
RESEND_API_KEY=re_WPcfKmf2_CC3LGDpJ6fwBs5oXkiALAq1h
RESEND_FROM_ADDRESS=info@colleaguestravel.com
RESEND_FROM_NAME=Colleagues Travel And Tours

# Previous SMTP configuration (inactive fallback)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_ADDRESS=info@colleagues-travel.com
# SMTP_FROM_NAME=Colleagues Travel
